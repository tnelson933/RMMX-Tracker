modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0", "stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 19869
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
STRIPE_PUBLISHABLE_KEY = "pk_test_51Tc3peDFpQsORJJyohzdcDeg4ouh3hIdyxyweycQs3NtHlPI27yHtwaCTPDa90QyficBo7w1HVvfZd90nxtydonX00jtbRZkXj"
